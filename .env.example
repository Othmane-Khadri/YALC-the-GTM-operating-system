# Required — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database — SQLite by default (local), swap for postgresql:// to use Postgres
DATABASE_URL=file:./gtm-os.db

# Required — encrypts stored API keys. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Optional — protects all /api/* routes with a bearer token.
# If unset, API routes are open (fine for local-only use).
# Generate with: openssl rand -hex 32
GTM_OS_API_TOKEN=

# Optional — enables the MCP server endpoint at /api/mcp-server.
# External AI agents use this token to authenticate.
# Generate with: openssl rand -hex 32
MCP_SERVER_TOKEN=

# LinkedIn — Unipile
UNIPILE_API_KEY=
UNIPILE_DSN=

# Web scraping — Firecrawl
FIRECRAWL_API_KEY=

# Company/people data — Crustdata
CRUSTDATA_API_KEY=

# Email enrichment — FullEnrich
FULLENRICH_API_KEY=

# Notion integration
NOTION_API_KEY=

# Cold email — Instantly.ai (https://instantly.ai)
INSTANTLY_API_KEY=

# Required for Vercel/Turso remote database
TURSO_AUTH_TOKEN=

# Google OAuth — sign in with Google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=
# Comma-separated list of allowed emails (empty = allow all)
ALLOWED_EMAILS=
