# ╔══════════════════════════════════════════════════════════════════════╗
# ║  GTM-OS Environment Variables                                       ║
# ║  Copy this file to .env.local: cp .env.example .env.local          ║
# ║  Or run: yalc-gtm start (guided wizard handles everything)     ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── REQUIRED ─────────────────────────────────────────────────────────────
# You need this to use GTM-OS at all. Everything else is optional.

# Anthropic (Claude) — powers all AI reasoning, framework derivation, qualification
# Get yours at: https://console.anthropic.com/settings/keys
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=

# ── INFRASTRUCTURE (auto-generated by `yalc-gtmstart`) ──────────────

# Database — SQLite by default (local, zero setup)
# For remote: use postgresql://... or libsql://... (Turso)
DATABASE_URL=file:./gtm-os.db

# Encrypts stored API keys in the database
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── OPTIONAL — TIER 2 (unlocks core features) ───────────────────────────
# Each key below enables specific capabilities. Add them as you need them.

# Unipile — LinkedIn outreach (connect, DM, profile scraping)
# Sign up:     https://www.unipile.com/?utm_source=partner&utm_campaign=Yalc
# Get API key: https://app.unipile.com/settings/api
# Unlocks: campaign:create, campaign:track, leads:scrape-post, linkedin:answer-comments
UNIPILE_API_KEY=
UNIPILE_DSN=

# Firecrawl — web scraping and search
# Get yours at: https://firecrawl.dev/app/api-keys
# Unlocks: website scraping during onboard, competitive-intel, web research
FIRECRAWL_API_KEY=

# Crustdata — company and people data (800M+ profiles, 200M+ companies)
# Get yours at: https://crustdata.com/dashboard/api
# Unlocks: find-companies, find-people, enrich-leads, lead qualification
CRUSTDATA_API_KEY=

# Notion — CRM sync, campaign tracking, lead databases
# Get yours at: https://www.notion.so/my-integrations
# Unlocks: notion:sync, notion:bootstrap, campaign tracking in Notion
NOTION_API_KEY=

# ── OPTIONAL — TIER 3 (specialized capabilities) ────────────────────────

# FullEnrich — email and phone number enrichment
# Sign up:     https://fullenrich.com?via=sNO0yIysrHzw
# Get API key: https://app.fullenrich.com/settings
# Unlocks: enrich-leads with contact info (email, phone)
FULLENRICH_API_KEY=

# Instantly.ai — cold email campaign management
# Sign up:     https://instantly.ai?via=yalc
# Get API key: https://instantly.ai/settings/api
# Unlocks: email:create-sequence, send-email-sequence, multi-channel campaigns
INSTANTLY_API_KEY=

# Orthogonal — universal API gateway (100+ APIs behind one key)
# Sign up:     https://www.orthogonal.com/?utm_source=yalc&utm_medium=referral&utm_campaign=in-app
# Get API key: https://orthogonal.com/sign-up ($5 free credits, no card required)
# Unlocks: fallback enrichment, additional search providers
ORTHOGONAL_API_KEY=

# PredictLeads — company-level signals: jobs, funding, technographics, news, similar companies
# Sign up:     https://predictleads.com/
# Get keys:    https://predictleads.com/account/api_subscriptions (issues TWO values together)
# Unlocks: signals:fetch, signals:show, signals:enrich, signals:similar
# Plan tiers bill 1 credit per call (typical 1k–10k credits/mo). Check live quota via the
# /api_subscription endpoint or run signals:fetch on any domain to see usage.
PREDICTLEADS_API_KEY=
PREDICTLEADS_API_TOKEN=

# ── BUNDLED DECLARATIVE PROVIDERS ────────────────────────────────────────
# Activated by manifests under `configs/adapters/`. No code change needed
# — drop the key in and the adapter goes from `unavailable` to `available`.

# People Data Labs — bulk people enrichment alternative to FullEnrich
# Get yours at: https://dashboard.peopledatalabs.com/main/api-keys
# Manifest: configs/adapters/people-enrich-peopledatalabs.yaml
# Capability: people-enrich (priority added via config.yaml override)
PEOPLEDATALABS_API_KEY=

# HubSpot — CRM contact upsert (Private App access token, NOT OAuth)
# Get yours at: https://developers.hubspot.com/docs/api/private-apps
# Manifest: configs/adapters/crm-contact-upsert-hubspot.yaml
# Capability: crm-contact-upsert (default)
HUBSPOT_API_KEY=

# Brevo (formerly Sendinblue) — email campaign create alternative to Instantly
# Get yours at: https://app.brevo.com/settings/keys/api
# Manifest: configs/adapters/email-campaign-create-brevo.yaml
# Capability: email-campaign-create (priority added via config.yaml override)
BREVO_API_KEY=

# ── API PROTECTION ───────────────────────────────────────────────────────

# Protects /api/* routes with a bearer token (optional for local-only use)
# Generate with: openssl rand -hex 32
GTM_OS_API_TOKEN=

# MCP server endpoint authentication (for external AI agents)
# Generate with: openssl rand -hex 32
MCP_SERVER_TOKEN=

# ── REMOTE DATABASE (optional) ──────────────────────────────────────────

# Turso auth token — only needed if using Turso/LibSQL remote database
TURSO_AUTH_TOKEN=

# ── GOOGLE OAUTH (optional — for web UI sign-in) ────────────────────────

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=
# Comma-separated list of allowed emails (empty = allow all)
ALLOWED_EMAILS=
